<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.bengebackend.mapper.ScriptAnalysisMapper">

    <!-- 根据 ScriptId 查询 -->
    <select id="getByScriptId" resultType="com.bengebackend.model.ScriptAnalysis">
        SELECT * FROM script_analysis WHERE script_id = #{scriptId}
    </select>

    <!-- 插入记录 -->
    <insert id="insert" parameterType="com.bengebackend.model.ScriptAnalysis" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO script_analysis (analysis_result, analyzed_at, script_id)
        VALUES (#{analysisResult}, #{analyzedAt}, #{scriptId})
    </insert>

    <!-- 更新记录 -->
    <update id="update" parameterType="com.bengebackend.model.ScriptAnalysis">
        UPDATE script_analysis
        SET analysis_result = #{analysisResult},
            analyzed_at = #{analyzedAt}
        WHERE script_id = #{scriptId}
    </update>

</mapper>
