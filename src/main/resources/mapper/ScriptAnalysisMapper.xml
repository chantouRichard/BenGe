<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bengebackend.mapper.ScriptAnalysisMapper">

    <resultMap id="BaseResultMap" type="com.bengebackend.model.ScriptAnalysis">
        <id column="id" property="id" jdbcType="INTEGER"/>
        <result column="script_id" property="scriptId" jdbcType="INTEGER"/>
        <result column="analysis_result" property="analysisResult" jdbcType="LONGVARCHAR"/>
        <result column="analyzed_at" property="analyzedAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, script_id, analysis_result, analyzed_at
    </sql>

    <select id="selectByScriptId" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List"/>
        FROM script_analysis 
        WHERE script_id = #{scriptId}
    </select>

    <insert id="insert" parameterType="com.bengebackend.model.ScriptAnalysis" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO script_analysis (
            script_id, analysis_result, analyzed_at
        ) VALUES (
            #{scriptId}, #{analysisResult}, #{analyzedAt}
        )
    </insert>

    <update id="updateByScriptId" parameterType="com.bengebackend.model.ScriptAnalysis">
        UPDATE script_analysis 
        SET analysis_result = #{analysisResult}, 
            analyzed_at = #{analyzedAt}
        WHERE script_id = #{scriptId}
    </update>

    <delete id="deleteById" parameterType="java.lang.Integer">
        DELETE FROM script_analysis WHERE id = #{id}
    </delete>

    <delete id="deleteByScriptId" parameterType="java.lang.Integer">
        DELETE FROM script_analysis WHERE script_id = #{scriptId}
    </delete>

</mapper>
